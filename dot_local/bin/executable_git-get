#!/bin/bash
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "Usage: git get <repo>" >&2
  echo "  git get github.com/user/repo" >&2
  echo "  git get user/repo" >&2
  echo "  git get git@github.com:user/repo.git" >&2
  exit 1
fi

input="$1"

# Parse the input into host/owner/repo
if [[ "$input" =~ ^git@([^:]+):(.+)\.git$ ]]; then
  host="${BASH_REMATCH[1]}"
  path="${BASH_REMATCH[2]}"
elif [[ "$input" =~ ^git@([^:]+):(.+)$ ]]; then
  host="${BASH_REMATCH[1]}"
  path="${BASH_REMATCH[2]}"
elif [[ "$input" =~ ^([^/]+)/([^/]+)/([^/]+)$ ]]; then
  host="${BASH_REMATCH[1]}"
  path="${BASH_REMATCH[2]}/${BASH_REMATCH[3]}"
elif [[ "$input" =~ ^([^/]+)/([^/]+)$ ]]; then
  host="github.com"
  path="${BASH_REMATCH[1]}/${BASH_REMATCH[2]}"
else
  echo "Error: cannot parse '$input'" >&2
  exit 1
fi

target="$HOME/git/$host/$path"
ssh_url="git@$host:$path.git"

if [ -d "$target" ]; then
  echo "Already exists: $target" >&2
  exit 1
fi

git clone --recurse-submodules "$ssh_url" "$target"
