[user]
    name = Jan Pokorný
    email = JenomPokorny@gmail.com

[column]
    ui = auto

[branch]
    sort = -committerdate

[tag]
    sort = version:refname

[diff]
    algorithm = histogram
    mnemonicPrefix = true
    renames = true

[push]
    default = simple
    autoSetupRemote = true

[fetch]
    prune = true
    pruneTags = true
    all = true

[help]
    autocorrect = prompt

[commit]
    verbose = true

[rerere]
    enabled = true
    autoupdate = true

[rebase]
    autoSquash = true
    autoStash = true
    updateRefs = true

[merge]
    conflictstyle = zdiff3

[pull]
    rebase = true

[init]
    defaultBranch = main

[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f

[alias]
    uncommit = "!git log -1 --pretty=%B && git reset --soft HEAD~1"
    main-branch = "!git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|.*/||' || echo main"
    branch-commit = "!f() { msg=\"$1\"; kebab=$(echo \"$msg\" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g' | sed -E 's/^-|-$//g'); git switch -c janpokorny/$kebab && git commit --signoff -m \"$msg\"; }; f"
    stash-keep = "!f() { ref=$(git stash create); [ -n \"$ref\" ] && git stash store \"$ref\" || echo 'Nothing to stash.'; }; f"

[sequence]
    editor = git-interactive-rebase-tool

[include]
    path = extra

[credential "https://github.com"]
    helper = !gh auth git-credential

[credential "https://gist.github.com"]
    helper = !gh auth git-credential
